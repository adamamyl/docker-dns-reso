#!/usr/bin/env bash
# dev-sast — run all SAST + linting checks for net-tester
set -euo pipefail; IFS=$'\n\t'

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV="${REPO_ROOT}/net_tester.venv"

# Targets: all Python source under net_tester, plus top-level installer scripts
TARGETS=("${REPO_ROOT}/net_tester" "${REPO_ROOT}/docker-dns-updater.py" "${REPO_ROOT}/install.py")

fail=0
run_step() {
  local name="$1"; shift
  echo "===================="
  echo "Running ${name}..."
  if ! "$@"; then
    echo "FAIL: ${name}" >&2
    fail=1
  fi
}

run_step "ruff check"   "${VENV}/bin/ruff" check "${TARGETS[@]}"
run_step "ruff format"  "${VENV}/bin/ruff" format --check "${TARGETS[@]}"
run_step "mypy"         "${VENV}/bin/mypy" "${REPO_ROOT}/net_tester"
run_step "bandit"       "${VENV}/bin/bandit" -c "${REPO_ROOT}/pyproject.toml" -r "${TARGETS[@]}" -ll

echo "===================="
if [[ "${fail}" -eq 0 ]]; then
  echo "All checks passed."
else
  echo "One or more checks failed." >&2
  exit 1
fi
