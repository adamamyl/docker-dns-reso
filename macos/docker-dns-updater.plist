<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
 "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.adamamyl.dnsupdater</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/docker-dns-updater.sh</string>
        <string>--force</string>
        <string>--update-profile</string>
    </array>
    <key>StartInterval</key>
    <integer>600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/docker-dns-updater.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/docker-dns-updater.err</string>
</dict>
</plist>
